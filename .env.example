# BuyPilot-AI backend runtime configuration.
# Copy this file to .env at the project root:
#   cp .env.example .env
# Then fill in the required values (marked with [REQUIRED]).
# Do not commit real API keys to version control.

# ============================================================================
# Application Settings
# ============================================================================

APP_NAME=buypilot-api
DEBUG=0
# DEBUG=1 enables verbose logging and stack traces. Keep off in production.

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL + pgvector is required for live RAG retrieval.
# Use docker-compose for a local instance:
#   docker compose -f deploy/docker-compose.yml up -d postgres
[REQUIRED] DATABASE_URL=postgresql+psycopg://buypilot:buypilot@localhost:5432/buypilot

# For SQLite (development only, no vector search):
# DATABASE_URL=sqlite:///./dev.db

# ============================================================================
# Data Directories
# ============================================================================

# Path to the official ecommerce dataset (100 products, 4 categories).
# Relative paths are resolved from the backend/ directory.
ECOMMERCE_DATASET_DIR=./data/raw/ecommerce_agent_dataset

# Directory for user-uploaded images (product photos for VLM analysis).
# Will be created automatically if it doesn't exist.
UPLOAD_DIR=./backend/uploads

# ============================================================================
# Startup & Seeding Behavior
# ============================================================================

# AUTO_SEED_ON_STARTUP=1 seeds the database with product data on API startup.
# Useful for docker-compose demos. Set to 0 for development to speed up startup.
AUTO_SEED_ON_STARTUP=0

# AUTO_SEED_STRICT_EMBEDDINGS=1 requires 1024-dim embeddings from the real
# Bailian provider. Set to 0 for development (uses 16-dim deterministic fallback).
AUTO_SEED_STRICT_EMBEDDINGS=0

# ============================================================================
# Runtime Mode
# ============================================================================

# STRICT_RUNTIME=1 disables all deterministic fallbacks (embedding, rerank, LLM).
# Use for live testing to expose provider failures. Keep off for development.
STRICT_RUNTIME=0

# ============================================================================
# AI Provider: Bailian / Alibaba Cloud (Qwen models)
# ============================================================================

# Base URL for Qwen-compatible endpoints (chat, embedding).
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# API key from https://bailian.console.aliyun.com/
# Format: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
[REQUIRED] BAILIAN_API_KEY=sk-your-bailian-api-key-here

# Models used by default (configured in llm_profiles.yaml):
#   - qwen-turbo: intent recognition
#   - qwen-plus: criteria generation, recommendation text
#   - qwen-vl-plus: image understanding
#   - text-embedding-v3: 1024-dim embeddings
#   - qwen3-rerank: text reranking (uses native DashScope API, not OpenAI-compat)

# ============================================================================
# AI Provider: Doubao / ByteDance (optional, used as fallback)
# ============================================================================

# Doubao is optional. If configured, it's used as primary for intent recognition
# (free tier has high quota). Leave blank to use Qwen for everything.
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=

# ============================================================================
# Cloudflare Tunnel (optional, for public HTTPS access)
# ============================================================================

# Create a tunnel in Cloudflare Zero Trust dashboard:
# 1. Go to Zero Trust > Access > Tunnels
# 2. Create a tunnel, set public hostname (e.g., api.yourdomain.com)
# 3. Configure service: http://api:8000
# 4. Copy the tunnel token here
CLOUDFLARE_TUNNEL_TOKEN=

# ============================================================================
# Advanced Settings (optional)
# ============================================================================

# ALLOW_MEMORY_STATE_FALLBACK=1 enables in-memory fallback for conversation
# state when database is unavailable. Only for development.
# ALLOW_MEMORY_STATE_FALLBACK=0

# LLM timeout and retry settings are in llm_profiles.yaml.
