# BuyPilot-AI backend runtime configuration.
# Copy values into .env at the project root. Do not commit real API keys.

APP_NAME=buypilot-api
DEBUG=0

# PostgreSQL + pgvector is required. Use docker-compose for a local instance.
DATABASE_URL=postgresql+psycopg://buypilot:buypilot@localhost:5432/buypilot

ECOMMERCE_DATASET_DIR=./data/raw/ecommerce_agent_dataset
UPLOAD_DIR=./backend/uploads

# Startup seeding is useful for compose demos, but keep it explicit.
AUTO_SEED_ON_STARTUP=0
AUTO_SEED_STRICT_EMBEDDINGS=0

# Legacy compatibility flag. Hidden deterministic/memory fallbacks are removed regardless of this value.
STRICT_RUNTIME=0

# Bailian / Qwen-compatible endpoints.
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_API_KEY=

# Secondary AI provider (Doubao). Fill these in to use Doubao as primary for intent.
DOUBAO_BASE_URL=
DOUBAO_API_KEY=

# Cloudflare Tunnel. Create a remotely-managed tunnel in Cloudflare Zero Trust,
# set its public hostname service URL to http://api:8000, then paste the token here.
# Do not commit real tunnel tokens.
CLOUDFLARE_TUNNEL_TOKEN=
