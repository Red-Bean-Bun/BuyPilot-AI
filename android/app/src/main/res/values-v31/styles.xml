<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BuyPilot" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">@drawable/startup_splash_background</item>
        <item name="android:windowSplashScreenBackground">@color/buy_pilot_splash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/buy_pilot_splash_background</item>
    </style>

    <style name="Theme.BuyPilot.Splash" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">@drawable/startup_splash_background</item>
        <item name="android:windowSplashScreenBackground">@color/buy_pilot_splash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/buy_pilot_splash_background</item>
    </style>
</resources>
